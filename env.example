# 微信凭证服务目录（token / cookie / rss.db，必填）
WECHAT_API_DIR=/path/to/wechat-api

# ── 数据库 ──
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/wxspirder

# ── SMTP 邮件（登录二维码 + 洞见报告）──
# 收件人列表（逗号分隔，支持 QQ + 公司邮箱等多人）
NOTIFY_EMAILS=you@qq.com,you@zte.com.cn
# 旧配置 NOTIFY_EMAIL 仍兼容，会自动合并进 NOTIFY_EMAILS
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=you@qq.com
SMTP_PASSWORD=your-smtp-auth-code
SMTP_FROM=you@qq.com
SMTP_USE_SSL=true

# ── 登录轮询与时间窗口 ──
LOGIN_POLL_INTERVAL=3
LOGIN_WINDOW_START=09:00
LOGIN_WINDOW_END=10:00
LOGIN_GRACE_SECONDS=600
QR_RESEND_INTERVAL=120
LOGIN_REMINDER_TIME=09:30

# ── 登录页（公网地址，留空则邮件仅含二维码图）──
LOGIN_SERVER_HOST=0.0.0.0
LOGIN_SERVER_PORT=8765
LOGIN_PUBLIC_URL=

# ── 文章正文抓取（/s/ 公开链接）──
ARTICLE_FETCH_DELAY=1.5
ARTICLE_FETCH_RETRIES=2
ARTICLE_FETCH_TIMEOUT=30

# ── Weekly Insights：云端 LLM（DeepSeek · Phase A/B/C，见 insight.yaml backend: cloud）──
# 在 https://platform.deepseek.com 获取 Key
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com
# 兼容别名（任选其一）：OPENAI_API_KEY= / LLM_API_KEY=

# ── Weekly Insights：本地 Ollama LLM（仅 profile 画像 backend: local 时需要）──
OLLAMA_LLM_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# ── Weekly Insights：Embedding（本地 Ollama bge-m3，必须）──
EMBEDDING_BACKEND=ollama
EMBEDDING_MODEL=bge-m3
OLLAMA_BASE_URL=http://localhost:11434

# ── 洞见报告邮件开关（覆盖 insight.yaml report.email_on_generate）──
# INSIGHT_REPORT_EMAIL=false

# ── 洞见 HTML 归档到博客（可选，无服务器时留空即可）──
# BLOG_ENABLED=true
# BLOG_PUBLISH_ON_GENERATE=true
# BLOG_SSH_PASSWORD=your-ssh-password
# BLOG_SSH_HOST=your-server-ip
# BLOG_SSH_USER=root
# BLOG_REMOTE_DIR=/var/www/insights
# BLOG_BASE_URL=https://your-blog.example.com
# insight.yaml blog.enabled=false 时，可用 BLOG_ENABLED=true 覆盖

# ── 数据库远程同步（可选，无远程服务器时留空即可）──
# 需 DATABASE_URL + BLOG_SSH_HOST；未配置时流水线自动跳过
# DB_SYNC_ENABLED=true
# DB_SYNC_SSH_HOST=          # 留空则复用 BLOG_SSH_HOST
# DB_SYNC_SSH_USER=root      # 留空则复用 BLOG_SSH_USER
# DB_SYNC_SSH_PASSWORD=      # 留空则复用 BLOG_SSH_PASSWORD
# DB_SYNC_REMOTE_DIR=/opt/wxspirder
# DB_SYNC_REMOTE_CONTAINER=wxspirder-pg
# DB_SYNC_REMOTE_USER=wx
# DB_SYNC_REMOTE_PASSWORD=wx
# DB_SYNC_REMOTE_DB=wxspirder

# ── 日志 ──
# LOG_DIR=worker/data/logs
# LOG_FILE=worker/data/logs/worker.log   # 总览日志（LOG_AGGREGATE=true 时含全量）
# LOG_LEVEL=INFO
# LOG_CONSOLE=true
# LOG_SPLIT=true          # 分项：crawl.log / insight.log / auth.log / schedule.log
# LOG_AGGREGATE=true      # 同时写 worker.log 全量时间线

# ── 每周自动调度（python -m worker schedule）──
# 提前提醒邮件：weekday=3（周四=3, 0=周一），默认周四 20:00
# SCHEDULE_REMINDER_DAY=3
# SCHEDULE_REMINDER_HOUR=20
# SCHEDULE_REMINDER_MINUTE=0
# 周一流水线启动时间（扫码窗口由 LOGIN_WINDOW_* 控制）
# SCHEDULE_PIPELINE_HOUR=9
# SCHEDULE_PIPELINE_MINUTE=0
